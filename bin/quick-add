#!/usr/bin/env php
<?php
/**
 * Quick Add — Fetch products from KicksDB and import to WooCommerce
 *
 * Accepts a single SKU or a JSON file with {SKU: title} pairs (same format
 * as catalog.json products). For each product, searches KicksDB using the
 * title as hint, verifies the SKU matches, normalizes, uploads images,
 * and imports to WC. Self-contained — no pipeline dependencies.
 *
 * To convert raw text lists into the expected JSON format, use:
 *   bin/parse-quick-add raw.txt -o products.json
 *
 * @package ResellPiacenza\Import
 */

require __DIR__ . '/../vendor/autoload.php';

use Monolog\Logger;
use ResellPiacenza\Support\Config;
use ResellPiacenza\Support\LoggerFactory;
use ResellPiacenza\KicksDb\Client as KicksDbClient;
use ResellPiacenza\Import\KicksDbAdapter;
use ResellPiacenza\Import\WcProductBuilder;
use ResellPiacenza\Import\WooCommerceImporter;

// ============================================================================
// CLI
// ============================================================================

if (in_array('--help', $argv) || in_array('-h', $argv)) {
    echo <<<HELP
Quick Add — Add products from KicksDB to WooCommerce

Usage:
  bin/quick-add --sku=DD1391-100                     # Single product
  bin/quick-add --sku=DD1391-100 "Nike Dunk Low"     # SKU + title hint
  bin/quick-add --file=products.json                  # Batch from JSON

JSON file format (same as catalog.json products):
  {
    "DD1391-100": "Nike Dunk Low Retro White Black",
    "FQ6965-700": "Nike Dunk Low LX Phantom Khaki (Women's)",
    "FD6900-200": ""
  }

  To convert raw text lists into this format:
    bin/parse-quick-add raw.txt -o products.json

Options:
  --sku=SKU                 Single product SKU
  --file=FILE               JSON file with {"SKU": "title"} pairs
  --category=KEY            Override WC category (sneakers|clothing|accessories)
  --skip-media              Don't upload images
  --dry-run                 Preview without importing
  --verbose, -v             Detailed output
  --help, -h                Show help

Examples:
  bin/quick-add --sku=DD1391-100
  bin/quick-add --sku=DD1391-100 "Nike Dunk Low Retro White Black"
  bin/quick-add --file=data/quick-add.json --dry-run --verbose
  bin/quick-add --file=data/quick-add.json --category=sneakers

Workflow:
  1. Prepare raw text with SKUs and titles
  2. bin/parse-quick-add raw.txt -o data/quick-add.json
  3. bin/quick-add --file=data/quick-add.json --dry-run
  4. bin/quick-add --file=data/quick-add.json

HELP;
    exit(0);
}

$opt_verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$opt_dry_run = in_array('--dry-run', $argv);
$opt_skip_media = in_array('--skip-media', $argv);
$opt_sku = null;
$opt_file = null;
$opt_category = null;
$opt_title = null;

foreach ($argv as $i => $arg) {
    if ($i === 0) continue;
    if (strpos($arg, '--sku=') === 0) {
        $opt_sku = str_replace('--sku=', '', $arg);
    } elseif (strpos($arg, '--file=') === 0) {
        $opt_file = str_replace('--file=', '', $arg);
    } elseif (strpos($arg, '--category=') === 0) {
        $opt_category = str_replace('--category=', '', $arg);
    } elseif (strpos($arg, '--env=') === 0) {
        // Handled by Config, ignore here
    } elseif (strpos($arg, '-') !== 0) {
        $opt_title = $arg;
    }
}

if (!$opt_sku && !$opt_file) {
    echo "Usage: bin/quick-add --sku=SKU or bin/quick-add --file=products.json\n";
    echo "Run bin/quick-add --help for details.\n";
    exit(1);
}

// ============================================================================
// Setup
// ============================================================================

$config = Config::load();
$start_time = microtime(true);

$logger = LoggerFactory::create('QuickAdd', [
    'file' => Config::projectRoot() . '/logs/quick-add.log',
    'console_level' => $opt_verbose ? Logger::DEBUG : Logger::INFO,
]);

$api_key = $config['pricing']['kicksdb_api_key'] ?? '';
if (empty($api_key)) {
    $logger->error('KICKSDB_API_KEY not set in .env');
    exit(1);
}

$market = $config['pricing']['kicksdb_market'] ?? 'IT';
$client = new KicksDbClient($api_key, [
    'base_url' => $config['pricing']['kicksdb_base_url'] ?? 'https://api.kicks.dev/v3',
], $logger);

// ============================================================================
// Build product list from input
// ============================================================================

$entries = []; // [{sku, title}, ...]

if ($opt_file) {
    // Batch mode: load JSON file
    $file_path = $opt_file;
    if ($file_path[0] !== '/') {
        $file_path = Config::projectRoot() . '/' . $file_path;
    }
    if (!file_exists($file_path)) {
        $logger->error("File not found: {$file_path}");
        exit(1);
    }

    $json = json_decode(file_get_contents($file_path), true);
    if (!is_array($json)) {
        $logger->error("Invalid JSON file: {$file_path}");
        exit(1);
    }

    // Format: {"SKU": "title", ...}
    foreach ($json as $sku => $title) {
        $entries[] = ['sku' => (string) $sku, 'title' => (string) $title];
    }

    if (empty($entries)) {
        $logger->error("No products found in {$opt_file}");
        exit(1);
    }
} else {
    // Single mode
    $entries[] = ['sku' => $opt_sku, 'title' => $opt_title ?? ''];
}

// ============================================================================
// Header
// ============================================================================

$total = count($entries);

$logger->info('');
$logger->info('========================================');
$logger->info('  Quick Add');
$logger->info('========================================');

if ($opt_file) {
    $logger->info("  File:     {$opt_file}");
}
$logger->info("  Products: {$total}");
if ($opt_category) {
    $logger->info("  Category: {$opt_category}");
}
if ($opt_skip_media) {
    $logger->info("  Media:    skipped");
}
if ($opt_dry_run) {
    $logger->warning('  DRY RUN');
}
$logger->info('');

// ============================================================================
// Process each product
// ============================================================================

$stats = ['ok' => 0, 'skipped' => 0, 'failed' => 0];
$wc_products = []; // Collect all WC payloads for batch import

foreach ($entries as $idx => $entry) {
    $sku = $entry['sku'];
    $title = $entry['title'];
    $progress = ($idx + 1) . "/{$total}";

    $logger->info("---------- [{$progress}] {$sku}" . ($title ? " — {$title}" : '') . " ----------");

    // ------------------------------------------------------------------
    // Step 1: Find product on KicksDB
    // ------------------------------------------------------------------

    $product_data = null;

    if (!empty($title)) {
        // Title-based search: more reliable for discovery, then verify SKU match
        $search = $client->browseProducts($title, 5, $market, 1, null, null, null, true);
        $candidates = $search['data'] ?? [];

        // Find exact SKU match among results
        foreach ($candidates as $c) {
            if (strcasecmp($c['sku'] ?? '', $sku) === 0) {
                $product_data = $c;
                break;
            }
        }

        if ($product_data === null && !empty($candidates)) {
            $logger->debug("  Title search: no SKU match among " . count($candidates) . " results");
        }
    }

    // Fallback: direct SKU lookup
    if ($product_data === null) {
        $result = $client->getStockXProduct($sku, $market);
        if ($result !== null) {
            $product_data = $result['data'] ?? $result;
            // Unwrap double-envelope
            if (isset($product_data['data']) && is_array($product_data['data']) && isset($product_data['data']['sku'])) {
                $product_data = $product_data['data'];
            }
        }
    }

    if ($product_data === null) {
        $logger->warning("  SKIP: not found on KicksDB");
        $stats['skipped']++;
        usleep(200000);
        continue;
    }

    // Verify SKU match
    $returned_sku = $product_data['sku'] ?? '';
    if (!empty($returned_sku) && strcasecmp($returned_sku, $sku) !== 0) {
        $returned_title = $product_data['title'] ?? $product_data['name'] ?? '?';
        $logger->warning("  SKIP: SKU mismatch — requested {$sku}, got {$returned_sku} ({$returned_title})");
        $stats['skipped']++;
        usleep(200000);
        continue;
    }

    $logger->info("  Found: " . ($product_data['title'] ?? '') . " ({$returned_sku})");

    // Ensure variants are loaded
    $variants = $product_data['variants'] ?? [];
    if (empty($variants)) {
        $product_id = $product_data['id'] ?? $product_data['slug'] ?? $sku;
        $logger->debug("  Fetching variants for {$product_id}...");
        $raw = $client->getStockXVariants($product_id, $market);
        if ($raw !== null) {
            $variants = $raw['data'] ?? $raw;
            $product_data['variants'] = $variants;
        }
    }

    if (empty($variants)) {
        $logger->warning("  SKIP: no variants (no sizes/prices)");
        $stats['skipped']++;
        usleep(200000);
        continue;
    }

    // ------------------------------------------------------------------
    // Step 2: Normalize via KicksDbAdapter
    // ------------------------------------------------------------------

    $adapter = new KicksDbAdapter($config, [$sku], $logger);
    $adapter->preloadFromAssortment([$sku => ['_raw' => $product_data]]);

    $normalized = null;
    foreach ($adapter->fetchProducts() as $product) {
        $normalized = $product;
        break;
    }

    if ($normalized === null) {
        $logger->warning("  SKIP: normalization failed (no valid variations?)");
        $stats['skipped']++;
        continue;
    }

    // Override category if specified
    if ($opt_category) {
        $normalized['category_type'] = $opt_category;
    }

    $logger->info("  Normalized: " . count($normalized['variations']) . " variations");

    // ------------------------------------------------------------------
    // Step 3: Upload images
    // ------------------------------------------------------------------

    if (!$opt_skip_media && !$opt_dry_run) {
        $image_url = $normalized['image_url'] ?? null;
        $gallery_urls = $normalized['gallery_urls'] ?? [];

        // Load existing image map
        $image_map_file = Config::imageMapFile();
        $image_map = [];
        if (file_exists($image_map_file)) {
            $image_map = json_decode(file_get_contents($image_map_file), true) ?: [];
        }

        if (isset($image_map[$sku]['media_id'])) {
            $logger->debug("  Image already uploaded: media_id={$image_map[$sku]['media_id']}");
        } elseif ($image_url) {
            $uploaded = uploadImage($config, $sku, $image_url, $normalized['name'], $normalized['brand'], $logger);
            if ($uploaded) {
                $image_map[$sku] = [
                    'media_id' => $uploaded,
                    'url' => $image_url,
                    'uploaded_at' => date('c'),
                    'gallery_ids' => [],
                ];
                $logger->info("  Image uploaded: media_id={$uploaded}");

                // Upload gallery (first 4 images to keep it fast)
                $gallery_ids = [];
                foreach (array_slice($gallery_urls, 0, 4) as $gal_idx => $gal_url) {
                    $gal_sku = $sku . '-gallery-' . ($gal_idx + 1);
                    $gal_id = uploadImage($config, $gal_sku, $gal_url, $normalized['name'], $normalized['brand'], $logger);
                    if ($gal_id) {
                        $gallery_ids[] = $gal_id;
                    }
                }
                $image_map[$sku]['gallery_ids'] = $gallery_ids;

                if (!empty($gallery_ids)) {
                    $logger->info("  Gallery: " . count($gallery_ids) . " images");
                }

                // Persist after each product (don't lose progress on failure)
                file_put_contents(
                    $image_map_file,
                    json_encode($image_map, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)
                );
            } else {
                $logger->warning("  Image upload failed, product will be created without image");
            }
        }
    }

    // ------------------------------------------------------------------
    // Step 4: Build WC payload
    // ------------------------------------------------------------------

    $builder = new WcProductBuilder($config, $logger);
    $wc_product = $builder->build($normalized);

    if ($wc_product === null) {
        $logger->warning("  SKIP: failed to build WC payload");
        $stats['failed']++;
        continue;
    }

    $type = $wc_product['type'] ?? 'variable';
    $var_count = count($wc_product['_variations'] ?? []);
    $img_count = count($wc_product['images'] ?? []);
    $logger->info("  Built: {$type}, {$var_count} variations, {$img_count} images");

    $wc_products[] = $wc_product;
    $stats['ok']++;

    usleep(200000); // 200ms between API calls
}

// ============================================================================
// Import to WooCommerce
// ============================================================================

if (empty($wc_products)) {
    $logger->error('No products to import');
    exit(1);
}

$logger->info('');

if ($opt_dry_run) {
    $logger->info('[DRY RUN] Would import ' . count($wc_products) . ' products:');
    foreach ($wc_products as $p) {
        $type = $p['type'] ?? 'variable';
        $vars = count($p['_variations'] ?? []);
        $imgs = count($p['images'] ?? []);
        $logger->info("  {$p['sku']} — {$p['name']} ({$type}, {$vars} vars, {$imgs} imgs)");
    }
} else {
    $logger->info('Importing ' . count($wc_products) . ' products to WooCommerce...');

    $importer = new WooCommerceImporter($config);
    $success = $importer->import($wc_products);

    if (!$success) {
        $logger->error('Import failed');
        exit(1);
    }
}

// ============================================================================
// Summary
// ============================================================================

$duration = round(microtime(true) - $start_time, 1);

$logger->info('');
$logger->info('========================================');
$logger->info('  QUICK ADD SUMMARY');
$logger->info('========================================');
$logger->info("  Total:     {$total}");
$logger->info("  Imported:  {$stats['ok']}");
$logger->info("  Skipped:   {$stats['skipped']}");
$logger->info("  Failed:    {$stats['failed']}");
$logger->info("  Duration:  {$duration}s");
$logger->info('========================================');

exit($stats['failed'] > 0 ? 1 : 0);

// ============================================================================
// Helper: Upload a single image to WordPress media library
// ============================================================================

/**
 * Download an image and upload it to WordPress media library
 *
 * @param array $config Application config
 * @param string $sku SKU for filename
 * @param string $url Image URL
 * @param string $product_name Product name for SEO metadata
 * @param string $brand Brand name for SEO metadata
 * @param object $logger Logger
 * @return int|null WordPress media ID or null on failure
 */
function uploadImage(array $config, string $sku, string $url, string $product_name, string $brand, $logger): ?int
{
    // Sanitize StockX CDN URLs (fm=webp → fm=jpg to avoid MIME mismatch)
    if (strpos($url, 'stockx') !== false) {
        $url = preg_replace('/([?&])fm=webp/', '$1fm=jpg', $url);
    }

    // Download
    $temp_file = tempnam(sys_get_temp_dir(), 'qa_img_');
    $ch = curl_init();
    curl_setopt_array($ch, [
        CURLOPT_URL => $url,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_FOLLOWLOCATION => true,
        CURLOPT_TIMEOUT => 30,
        CURLOPT_SSL_VERIFYPEER => false,
        CURLOPT_USERAGENT => 'Mozilla/5.0',
    ]);
    $content = curl_exec($ch);
    $http_code = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    curl_close($ch);

    if ($http_code !== 200 || empty($content)) {
        @unlink($temp_file);
        $logger->warning("  Image download failed: HTTP {$http_code} for {$url}");
        return null;
    }

    file_put_contents($temp_file, $content);

    // Validate
    $info = @getimagesize($temp_file);
    if ($info === false) {
        @unlink($temp_file);
        $logger->warning("  Invalid image format: {$url}");
        return null;
    }

    $mime = $info['mime'];
    $ext = image_type_to_extension($info[2], false);

    // Upload to WordPress
    $filename = preg_replace('/[^a-zA-Z0-9._-]/', '', $sku) . '.' . $ext;
    $store = $config['store']['name'] ?? 'ResellPiacenza';

    $alt_text = str_replace(
        ['{product_name}', '{brand_name}', '{sku}', '{store_name}'],
        [$product_name, $brand, $sku, $store],
        $config['templates']['image_alt'] ?? '{product_name}'
    );

    $boundary = 'QuickAddUpload' . time() . rand(1000, 9999);
    $file_content = file_get_contents($temp_file);

    $body = "--{$boundary}\r\n";
    $body .= "Content-Disposition: form-data; name=\"file\"; filename=\"{$filename}\"\r\n";
    $body .= "Content-Type: {$mime}\r\n\r\n";
    $body .= $file_content . "\r\n";

    foreach (['title' => $product_name, 'alt_text' => $alt_text] as $field => $value) {
        $body .= "--{$boundary}\r\n";
        $body .= "Content-Disposition: form-data; name=\"{$field}\"\r\n\r\n";
        $body .= $value . "\r\n";
    }
    $body .= "--{$boundary}--\r\n";

    $wp_url = rtrim($config['woocommerce']['url'], '/') . '/wp-json/wp/v2/media';
    $auth = base64_encode(
        $config['wordpress']['username'] . ':' .
        $config['wordpress']['app_password']
    );

    $ch = curl_init();
    curl_setopt_array($ch, [
        CURLOPT_URL => $wp_url,
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_POST => true,
        CURLOPT_POSTFIELDS => $body,
        CURLOPT_HTTPHEADER => [
            "Authorization: Basic {$auth}",
            "Content-Type: multipart/form-data; boundary={$boundary}",
        ],
        CURLOPT_TIMEOUT => 60,
    ]);

    $response = curl_exec($ch);
    $http_code = curl_getinfo($ch, CURLINFO_HTTP_CODE);
    curl_close($ch);

    @unlink($temp_file);

    if ($http_code !== 201) {
        $error = json_decode($response, true);
        $msg = $error['message'] ?? "HTTP {$http_code}";
        $logger->warning("  Image upload failed: {$msg}");
        return null;
    }

    $result = json_decode($response, true);
    return $result['id'] ?? null;
}
