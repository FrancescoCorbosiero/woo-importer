#!/usr/bin/env php
<?php
/**
 * Catalog Transform — Merged assortment → WooCommerce REST format
 *
 * Replaces unified-transform with cleaner architecture:
 * - Category comes from catalog's wc_category (no normalizeCategoryType hacks)
 * - Brand enrichment only for discovery=brand sections (no hardcoded skip)
 * - GS variation overlay via FeedMerger (unchanged)
 *
 * Pipeline: merged-assortment.json → KicksDbAdapter → FeedMerger → WcProductBuilder
 *
 * Input:
 *   data/merged-assortment.json    (from gs-ingest, or kicksdb-assortment.json fallback)
 *
 * Output:
 *   data/feed-wc-latest.json       (WC REST API formatted products)
 *
 * @package ResellPiacenza\Import
 */

require __DIR__ . '/../vendor/autoload.php';

use Monolog\Logger;
use ResellPiacenza\Support\Config;
use ResellPiacenza\Support\LoggerFactory;
use ResellPiacenza\Import\KicksDbAdapter;
use ResellPiacenza\Import\GoldenSneakersAdapter;
use ResellPiacenza\Import\FeedMerger;
use ResellPiacenza\Import\WcProductBuilder;

// ============================================================================
// CLI
// ============================================================================

if (in_array('--help', $argv) || in_array('-h', $argv)) {
    echo <<<HELP
Catalog Transform
Transforms the merged assortment into WooCommerce REST API format.

Usage:
  bin/catalog-transform [options]

Options:
  --limit=N         Transform first N products only
  --skip-gs         Skip GS variation overlay
  --no-cache        Bypass KicksDB product cache (force fresh API fetch)
  --verbose, -v     Detailed output
  --help, -h        Show help

Requires:
  data/merged-assortment.json   (from gs-ingest)
  OR data/kicksdb-assortment.json (fallback, from kicksdb-discover)
  data/taxonomy-map.json         (from prepare-taxonomies)
  image-map.json                 (from prepare-media, optional)

Output:
  data/feed-wc-latest.json - WooCommerce REST API formatted products

Examples:
  bin/catalog-transform                    # Full transform
  bin/catalog-transform --limit=10         # First 10 products
  bin/catalog-transform --skip-gs          # No GS overlay
  bin/catalog-transform --verbose          # Detailed output

HELP;
    exit(0);
}

$verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$skip_gs = in_array('--skip-gs', $argv);
$no_cache = in_array('--no-cache', $argv);
$limit = null;

foreach ($argv as $arg) {
    if (strpos($arg, '--limit=') === 0) {
        $limit = (int) str_replace('--limit=', '', $arg);
    }
}

// ============================================================================
// Setup
// ============================================================================

$config = Config::load();
$start_time = microtime(true);

$logger = LoggerFactory::create('CatalogTransform', [
    'file' => Config::projectRoot() . '/logs/catalog-transform.log',
    'console_level' => $verbose ? Logger::DEBUG : Logger::INFO,
]);

$logger->info('');
$logger->info('================================');
$logger->info('  Catalog Transform');
$logger->info('  Merged assortment → WC REST format');
$logger->info('================================');
$logger->info('');

// ============================================================================
// Load assortment (merged preferred, KicksDB fallback)
// ============================================================================

$merged_file = Config::dataDir() . '/merged-assortment.json';
$kdb_file = Config::dataDir() . '/kicksdb-assortment.json';

$assortment = null;
$assortment_source = '';

if (file_exists($merged_file)) {
    $assortment = json_decode(file_get_contents($merged_file), true);
    $assortment_source = 'merged-assortment.json';
} elseif (file_exists($kdb_file)) {
    $assortment = json_decode(file_get_contents($kdb_file), true);
    $assortment_source = 'kicksdb-assortment.json (fallback)';
}

if (!is_array($assortment) || empty($assortment['products'])) {
    $logger->error("No assortment file found. Run bin/kicksdb-discover and/or bin/gs-ingest first.");
    exit(1);
}

$products = $assortment['products'];
$logger->info("Loaded assortment: " . count($products) . " products from {$assortment_source}");

// Extract SKU list for KicksDB adapter
$skus = array_values(array_filter(array_column($products, 'sku')));

if ($limit && count($skus) > $limit) {
    $skus = array_slice($skus, 0, $limit);
    $logger->info("  Limited to first {$limit}");
}

$logger->info("  " . count($skus) . " SKUs to transform");

// ============================================================================
// Build assortment lookup maps
// ============================================================================

// SKU → assortment product (for category override + brand enrichment)
$assortment_map = [];
foreach ($products as $p) {
    $sku = $p['sku'] ?? '';
    if ($sku) {
        $assortment_map[$sku] = $p;
    }
}

// ============================================================================
// Fetch from both sources
// ============================================================================

try {
    // KicksDB adapter: uses pre-loaded assortment data when available (zero API calls)
    if ($no_cache) {
        $config['import']['kicksdb_cache_ttl'] = 0;
        $logger->info('  KicksDB cache: disabled (--no-cache)');
    }
    $kdbAdapter = new KicksDbAdapter($config, $skus, $logger);

    // Pre-load rich product data from discovery (avoids per-SKU API calls)
    $kdbAdapter->preloadFromAssortment($assortment_map);

    $pricing_summary = $kdbAdapter->getPricingSummary();
    $logger->info("  KicksDB pricing: flat {$pricing_summary['flat_margin']}, floor {$pricing_summary['floor_price']}, rounding {$pricing_summary['rounding']}");
    if (!empty($pricing_summary['tiers'])) {
        foreach ($pricing_summary['tiers'] as $tier) {
            $logger->info("    Tier: {$tier}");
        }
    }
    $logger->info('');

    // Collect KicksDB normalized products with category override from catalog
    $logger->info('Fetching KicksDB products...');
    $kdbProducts = [];
    foreach ($kdbAdapter->fetchProducts() as $p) {
        $sku = $p['sku'] ?? '';

        // Category override: use wc_category from catalog when available
        // This replaces the old section_map hack — category is authoritative from the catalog
        if (isset($assortment_map[$sku]['catalog_wc_category'])) {
            $wc_cat = $assortment_map[$sku]['catalog_wc_category'];
            if ($wc_cat) {
                $p['category_type'] = $wc_cat;
            }
        }

        $kdbProducts[] = $p;
    }
    $logger->info("  KicksDB: " . count($kdbProducts) . " products normalized");

    // GS adapter (unless --skip-gs)
    $gsProducts = [];
    if (!$skip_gs) {
        $logger->info('');
        $logger->info('Fetching Golden Sneakers products...');
        $gsAdapter = new GoldenSneakersAdapter($config, $logger);
        foreach ($gsAdapter->fetchProducts() as $p) {
            $gsProducts[] = $p;
        }
        $logger->info("  GS: " . count($gsProducts) . " products normalized");
    } else {
        $logger->info('Skipping GS overlay (--skip-gs)');
    }

    // ========================================================================
    // Merge
    // ========================================================================

    $logger->info('');
    $logger->info('Merging feeds (variation-level)...');

    $merger = new FeedMerger($logger);
    $mergedProducts = $merger->merge($kdbProducts, $gsProducts);

    $merge_stats = $merger->getStats();
    $logger->info("  Merged:       {$merge_stats['products_merged']} products");
    $logger->info("  KicksDB-only: {$merge_stats['products_kicksdb_only']} products");
    $logger->info("  GS-only:      {$merge_stats['products_gs_only']} products");
    $logger->info("  Variations - GS overlay: {$merge_stats['variations_gs_overlay']}, KDB-only: {$merge_stats['variations_kicksdb_only']}, GS-only: {$merge_stats['variations_gs_only']}");

    // ========================================================================
    // Build WC format
    // ========================================================================

    $logger->info('');
    $logger->info('Building WooCommerce payloads...');

    $builder = new WcProductBuilder($config, $logger);
    $builder->setStockOverride(null); // Use adapter/merger-provided stock
    $wc_products = $builder->buildAll($mergedProducts);

    // Sort + menu_order assignment
    // Curated catalog: use _catalog_position (preserves catalog.json order)
    // Discovery mode: use release_date (newest first)
    $has_catalog_positions = false;
    foreach ($assortment_map as $meta) {
        if (isset($meta['_catalog_position'])) {
            $has_catalog_positions = true;
            break;
        }
    }

    if ($has_catalog_positions) {
        $logger->info("Menu order: catalog position (curated mode)");
        usort($wc_products, function ($a, $b) use ($assortment_map) {
            $pos_a = $assortment_map[$a['sku'] ?? '']['_catalog_position'] ?? PHP_INT_MAX;
            $pos_b = $assortment_map[$b['sku'] ?? '']['_catalog_position'] ?? PHP_INT_MAX;
            if ($pos_a !== $pos_b) {
                return $pos_a - $pos_b;
            }
            // Fallback for products without catalog position (GS-only)
            $date_a = 0;
            $date_b = 0;
            foreach ($a['meta_data'] ?? [] as $m) {
                if ($m['key'] === '_release_date' && !empty($m['value'])) {
                    $date_a = strtotime(preg_replace('/T.*$/', '', $m['value'])) ?: 0;
                    break;
                }
            }
            foreach ($b['meta_data'] ?? [] as $m) {
                if ($m['key'] === '_release_date' && !empty($m['value'])) {
                    $date_b = strtotime(preg_replace('/T.*$/', '', $m['value'])) ?: 0;
                    break;
                }
            }
            return $date_b - $date_a;
        });
    } else {
        $logger->info("Menu order: release date (discovery mode)");
        usort($wc_products, function ($a, $b) {
            $date_a = 0;
            $date_b = 0;
            foreach ($a['meta_data'] ?? [] as $m) {
                if ($m['key'] === '_release_date' && !empty($m['value'])) {
                    $date_a = strtotime(preg_replace('/T.*$/', '', $m['value'])) ?: 0;
                    break;
                }
            }
            foreach ($b['meta_data'] ?? [] as $m) {
                if ($m['key'] === '_release_date' && !empty($m['value'])) {
                    $date_b = strtotime(preg_replace('/T.*$/', '', $m['value'])) ?: 0;
                    break;
                }
            }
            return $date_b - $date_a; // Newest first
        });
    }

    foreach ($wc_products as $idx => &$wc_tmp) {
        $wc_tmp['menu_order'] = $idx;
    }
    unset($wc_tmp);

    // ========================================================================
    // Catalog provenance metadata (ALL products)
    // ========================================================================

    $catalog = $assortment['catalog'] ?? null;
    $taxonomy_map_file = Config::dataDir() . '/taxonomy-map.json';
    $taxonomy_map = file_exists($taxonomy_map_file)
        ? (json_decode(file_get_contents($taxonomy_map_file), true) ?: [])
        : [];
    $brands_map = $taxonomy_map['brands'] ?? [];
    $subcategories_map = $taxonomy_map['subcategories'] ?? [];

    $catalog_indexed = 0;
    $catalog_brand_enriched = 0;

    // Build lookup of wc_category keys that have explicit subcategories (keyword-based)
    // For those sections, catalog_subcategory is a garment type query, NOT a brand hierarchy
    $keyword_subcat_sections = [];
    if ($catalog && !empty($catalog['sections'])) {
        foreach ($catalog['sections'] as $section) {
            if (!empty($section['subcategories'])) {
                $keyword_subcat_sections[$section['wc_category'] ?? ''] = true;
            }
        }
    }
    foreach ($wc_products as &$wc) {
        $sku = $wc['sku'] ?? '';
        if (!isset($assortment_map[$sku])) {
            continue;
        }

        $meta = $assortment_map[$sku];
        $wc['meta_data'] = $wc['meta_data'] ?? [];

        // --- Catalog provenance: persisted for ALL products regardless of discovery mode ---
        $catalog_section = $meta['catalog_section'] ?? '';
        $catalog_discovery = $meta['catalog_discovery'] ?? '';
        $catalog_wc_category = $meta['catalog_wc_category'] ?? '';
        $catalog_brand = $meta['catalog_brand'] ?? '';
        $catalog_subcategory = $meta['catalog_subcategory'] ?? '';

        if ($catalog_section) {
            $wc['meta_data'][] = ['key' => '_catalog_section', 'value' => $catalog_section];
        }
        if ($catalog_discovery) {
            $wc['meta_data'][] = ['key' => '_catalog_discovery', 'value' => $catalog_discovery];
        }
        if ($catalog_wc_category) {
            $wc['meta_data'][] = ['key' => '_catalog_wc_category', 'value' => $catalog_wc_category];
        }
        if ($catalog_brand) {
            $wc['meta_data'][] = ['key' => '_catalog_brand', 'value' => $catalog_brand];
        }
        if ($catalog_subcategory) {
            $wc['meta_data'][] = ['key' => '_catalog_subcategory', 'value' => $catalog_subcategory];
        }

        // --- GS catalog tag: marks products present in the Golden Sneakers catalog ---
        // Enables querying all GS products via WC meta, and future sale badge support
        $is_gs = !empty($meta['gs_tracked'])
            || $catalog_discovery === 'gs_enriched'
            || $catalog_discovery === 'gs_only';
        if ($is_gs) {
            $wc['meta_data'][] = ['key' => '_gs_catalog', 'value' => '1'];
        }

        // --- Sub-category assignment: add product to hierarchical WC sub-category ---
        // Two modes depending on taxonomy-map format:
        //   1. Keyword-based (Abbigliamento): match query/title against keywords → garment type
        //      e.g. "Supreme Hoodie" matches keyword "hoodie" → Felpe
        //   2. Direct slug (Sneakers, Accessori): slugify catalog_subcategory → match slug
        //      e.g. "Nike Dunk" → slug "nike-dunk" → Sneakers > Nike Dunk
        // NOTE: brand names stay in pa_marca only, never used as product categories.
        if ($catalog_wc_category) {
            $cat_config = $config['categories'][$catalog_wc_category] ?? null;
            $parent_slug = $cat_config['slug'] ?? '';
            $parent_subcats = $subcategories_map[$parent_slug] ?? [];

            $matched_subcat_id = null;

            // Check if this parent uses keyword-based subcategories
            // (entries are arrays with 'id' + 'keywords' instead of plain int IDs)
            $first_entry = reset($parent_subcats);
            $uses_keywords = is_array($first_entry) && isset($first_entry['keywords']);

            if ($uses_keywords) {
                // Keyword matching: search query label + product title for garment type keywords
                $searchable = strtolower($catalog_subcategory . ' ' . ($wc['name'] ?? ''));
                foreach ($parent_subcats as $slug => $entry) {
                    foreach ($entry['keywords'] ?? [] as $kw) {
                        if (strpos($searchable, $kw) !== false) {
                            $matched_subcat_id = $entry['id'];
                            break 2;
                        }
                    }
                }
            } else {
                // Direct slug matching
                $subcat_name = $catalog_subcategory;
                if ($subcat_name) {
                    $subcat_slug = strtolower(preg_replace('/[^a-z0-9-]/i', '-', $subcat_name));
                    $subcat_slug = preg_replace('/-+/', '-', trim($subcat_slug, '-'));
                    $matched_subcat_id = $parent_subcats[$subcat_slug] ?? null;
                }
            }

            if ($matched_subcat_id) {
                $existing_cat_ids = array_column($wc['categories'] ?? [], 'id');
                if (!in_array($matched_subcat_id, $existing_cat_ids)) {
                    $wc['categories'][] = ['id' => $matched_subcat_id];
                }
            }
        }

        $catalog_indexed++;

        // --- Brand taxonomy enrichment: for brand/curated discovery with brand set ---
        // Query-mode items (Accessori) don't have brand hierarchies in the catalog
        if (empty($catalog_brand) || ($catalog_discovery !== 'brand' && $catalog_discovery !== 'curated')) {
            continue;
        }

        $brand_slug = strtolower(preg_replace('/[^a-z0-9-]/i', '-', $catalog_brand));
        $brand_slug = preg_replace('/-+/', '-', trim($brand_slug, '-'));
        $parent_brand_id = $brands_map[$brand_slug] ?? null;

        $brand_entries = [];

        // Parent brand (always): e.g. "Nike", "Sp5der", "Supreme"
        if ($parent_brand_id) {
            $brand_entries[] = ['id' => $parent_brand_id];
        } else {
            $brand_entries[] = ['slug' => $brand_slug, 'name' => $catalog_brand];
        }

        // Sub-brand (only for sections WITHOUT keyword subcategories):
        // Sneakers: "Nike Dunk" is a real sub-brand under "Nike" → add it
        // Abbigliamento: "Sp5der Pants" is brand+garment query, NOT a sub-brand → skip
        $has_keyword_subcats = isset($keyword_subcat_sections[$catalog_wc_category]);
        if (!$has_keyword_subcats && !empty($catalog_subcategory) && $catalog_subcategory !== $catalog_brand) {
            $subcat_slug = strtolower(preg_replace('/[^a-z0-9-]/i', '-', $catalog_subcategory));
            $subcat_slug = preg_replace('/-+/', '-', trim($subcat_slug, '-'));
            $subcat_brand_id = $brands_map[$subcat_slug] ?? null;

            if ($subcat_brand_id) {
                if ($subcat_brand_id !== $parent_brand_id) {
                    $brand_entries[] = ['id' => $subcat_brand_id];
                }
            } else {
                $brand_entries[] = ['slug' => $subcat_slug, 'name' => $catalog_subcategory];
            }
        }

        $existing = $wc['brands'] ?? [];
        $existing_ids = array_filter(array_column($existing, 'id'));
        $existing_slugs = array_filter(array_column($existing, 'slug'));
        foreach ($brand_entries as $b) {
            if (!empty($b['id']) && !in_array($b['id'], $existing_ids)) {
                $existing[] = $b;
            } elseif (!empty($b['slug']) && !in_array($b['slug'], $existing_slugs)) {
                $existing[] = $b;
            }
        }
        $wc['brands'] = $existing;

        $catalog_brand_enriched++;
    }
    unset($wc);

    $logger->info("Catalog provenance: {$catalog_indexed}/" . count($wc_products) . " products indexed");
    $logger->info("Brand enrichment: {$catalog_brand_enriched}/" . count($wc_products) . " products assigned sub-brands");

    // ========================================================================
    // Write output
    // ========================================================================

    $output_file = Config::dataDir() . '/feed-wc-latest.json';
    file_put_contents(
        $output_file,
        json_encode($wc_products, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)
    );

    // Cache unified SKUs for cross-pipeline dedup
    $unified_skus = array_values(array_filter(array_map(fn($p) => $p['sku'] ?? null, $wc_products)));
    file_put_contents(Config::dataDir() . '/unified-sku-cache.json', json_encode($unified_skus, JSON_PRETTY_PRINT));
    $logger->info("Cached " . count($unified_skus) . " SKUs to unified-sku-cache.json");

    // ========================================================================
    // Summary
    // ========================================================================

    $duration = round(microtime(true) - $start_time, 1);
    $kdb_stats = $kdbAdapter->getStats();
    $gs_stats = isset($gsAdapter) ? $gsAdapter->getStats() : null;
    $builder_stats = $builder->getStats();

    $logger->info('');
    $logger->info('================================');
    $logger->info('  CATALOG TRANSFORM SUMMARY');
    $logger->info('================================');
    $logger->info("  Assortment source:    {$assortment_source}");
    $logger->info("  KicksDB SKUs:         {$kdb_stats['total_skus']}");
    $logger->info("  KicksDB found:        {$kdb_stats['products_found']}");
    $logger->info("  KicksDB preloaded:    {$kdb_stats['preloaded_hits']}");
    $logger->info("  KicksDB cache hits:   {$kdb_stats['cache_hits']}");
    $logger->info("  KicksDB API fetches:  {$kdb_stats['api_fetches']}");
    $logger->info("  KicksDB not found:    {$kdb_stats['products_not_found']}");
    if ($gs_stats) {
        $logger->info("  GS products:          {$gs_stats['fetched']}");
    } else {
        $logger->info("  GS: skipped (--skip-gs)");
    }
    $logger->info("  ---");
    $logger->info("  Merged (both):        {$merge_stats['products_merged']}");
    $logger->info("  KicksDB-only:         {$merge_stats['products_kicksdb_only']}");
    $logger->info("  GS-only:              {$merge_stats['products_gs_only']}");
    $logger->info("  ---");
    $logger->info("  WC products built:    {$builder_stats['transformed']}");
    $logger->info("  With image:           {$builder_stats['with_image']}");
    $logger->info("  With gallery:         {$builder_stats['with_gallery']}");
    $logger->info("  Without image:        {$builder_stats['without_image']}");
    $logger->info("  Catalog indexed:      {$catalog_indexed}");
    $logger->info("  Brand enriched:       {$catalog_brand_enriched}");
    $logger->info("  Duration:             {$duration}s");
    $logger->info("  Output:               {$output_file}");
    $logger->info('================================');

    exit(0);

} catch (\Exception $e) {
    $logger->error('Error: ' . $e->getMessage());
    exit(1);
}
