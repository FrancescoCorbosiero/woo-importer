#!/usr/bin/env php
<?php
/**
 * CLI wrapper for Shopify CSV Directory Import
 *
 * Scans a directory for Shopify product export CSV files, parses them,
 * and imports products into WooCommerce via the BulkUploader pipeline.
 *
 * Handles the full pipeline: CSV parsing → taxonomy creation → image upload → WC import.
 *
 * @package ResellPiacenza\Import
 */

require __DIR__ . '/../vendor/autoload.php';

use ResellPiacenza\Support\Config;
use ResellPiacenza\Import\ShopifyCsvParser;
use ResellPiacenza\Import\BulkUploader;

// ============================================================================
// CLI
// ============================================================================

if (in_array('--help', $argv) || in_array('-h', $argv)) {
    echo <<<HELP
Shopify CSV Directory Import
Import products from Shopify CSV export files into WooCommerce.

Usage:
  bin/import-dir --dir=DIR [options]

Options:
  --dir=DIR             Directory containing Shopify CSV exports - required
  --dry-run             Preview without importing (no API calls)
  --skip-media          Don't upload images (use URLs directly via sideload)
  --verbose, -v         Detailed output
  --limit=N             Import only the first N products
  --help, -h            Show help

Example:
  bin/import-dir --dir=import/ --dry-run --verbose
  bin/import-dir --dir=import/ --limit=5
  bin/import-dir --dir=/path/to/exports/ --skip-media

The script will:
  1. Scan the directory for all .csv files
  2. Parse each as a Shopify product export
  3. Extract brands from Tags, SKUs from descriptions
  4. Auto-detect categories (sneakers vs clothing) from size format
  5. Upload images to WordPress media library
  6. Import products to WooCommerce with Italian SEO metadata

HELP;
    exit(0);
}

// Parse CLI options
$dry_run = in_array('--dry-run', $argv);
$verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$skip_media = in_array('--skip-media', $argv);
$dir = null;
$limit = null;

foreach ($argv as $arg) {
    if (strpos($arg, '--dir=') === 0) {
        $dir = str_replace('--dir=', '', $arg);
    }
    if (strpos($arg, '--limit=') === 0) {
        $limit = (int) str_replace('--limit=', '', $arg);
    }
}

if (!$dir) {
    echo "Error: --dir=DIR is required. Use --help for usage.\n";
    exit(1);
}

// Resolve relative paths
if ($dir[0] !== '/') {
    $dir = Config::projectRoot() . '/' . $dir;
}

if (!is_dir($dir)) {
    echo "Error: Directory not found: {$dir}\n";
    exit(1);
}

// ============================================================================
// Parse
// ============================================================================

echo "\n";
echo "================================\n";
echo "  Shopify CSV Directory Import\n";
echo "================================\n";
echo "  Directory: {$dir}\n";

if ($dry_run) {
    echo "  Mode: DRY RUN\n";
}
if ($skip_media) {
    echo "  Media: SKIP (sideload via URL)\n";
}
if ($limit) {
    echo "  Limit: {$limit} products\n";
}

echo "\n";

// Step 1: Parse Shopify CSVs
echo "Step 1: Parsing Shopify CSV files...\n";

$parser = new ShopifyCsvParser(['verbose' => $verbose]);
$products = $parser->parseDirectory($dir);

$stats = $parser->getStats();

echo "  Files parsed:  {$stats['files_parsed']}\n";
echo "  Rows read:     {$stats['rows_read']}\n";
echo "  Products:      {$stats['products_parsed']} parsed, {$stats['products_skipped']} skipped\n";
echo "  SKU sources:   {$stats['skus_from_description']} from description, " .
     "{$stats['skus_from_variant']} from variant, {$stats['skus_generated']} generated\n";
echo "  Brands found:  " . implode(', ', $stats['brands_detected']) . "\n";

if (empty($products)) {
    echo "\nNo products found. Nothing to import.\n";
    exit(0);
}

// Apply limit
if ($limit && $limit < count($products)) {
    $products = array_slice($products, 0, $limit);
    echo "\n  Limited to first {$limit} products\n";
}

// Step 2: Write intermediate JSON for BulkUploader
$feed_file = Config::dataDir() . '/shopify-import-feed.json';
file_put_contents(
    $feed_file,
    json_encode($products, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)
);

echo "\n  Wrote: {$feed_file}\n";

// Step 3: Run BulkUploader pipeline
echo "\nStep 2: Running BulkUploader pipeline...\n\n";

$config = Config::load();
$uploader = new BulkUploader($config, [
    'dry_run' => $dry_run,
    'verbose' => $verbose,
    'skip_media' => $skip_media,
    'skip_existing' => true,
    'file' => $feed_file,
]);

$success = $uploader->run();

exit($success ? 0 : 1);
