#!/usr/bin/env php
<?php
/**
 * CLI wrapper for Shopify CSV Directory Import
 *
 * Scans a directory for Shopify product export CSV files, parses them,
 * and imports products into WooCommerce via CatalogPipeline.
 *
 * Pipeline: ShopifyCsvParser → BulkUploadAdapter → CatalogPipeline
 *
 * @package ResellPiacenza\Import
 */

require __DIR__ . '/../vendor/autoload.php';

use Monolog\Logger;
use ResellPiacenza\Support\Config;
use ResellPiacenza\Support\LoggerFactory;
use ResellPiacenza\Import\BulkUploadAdapter;
use ResellPiacenza\Import\CatalogPipeline;

// ============================================================================
// CLI
// ============================================================================

if (in_array('--help', $argv) || in_array('-h', $argv)) {
    echo <<<HELP
Shopify CSV Directory Import
Import products from Shopify CSV export files into WooCommerce.

Usage:
  bin/import-dir --dir=DIR [options]

Options:
  --dir=DIR             Directory containing Shopify CSV exports - required
  --dry-run             Preview without importing (no API calls)
  --skip-media          Don't upload images (use URLs directly via sideload)
  --skip-taxonomies     Skip taxonomy preparation step
  --verbose, -v         Detailed output
  --force-full          Force full import (ignore delta)
  --limit=N             Import only the first N products
  --env=FILE            Use alternate .env file
  --help, -h            Show help

Example:
  bin/import-dir --dir=import/ --dry-run --verbose
  bin/import-dir --dir=import/ --limit=5
  bin/import-dir --dir=/path/to/exports/ --skip-media

The script will:
  1. Scan the directory for all .csv files
  2. Parse each as a Shopify product export
  3. Extract brands from Tags, SKUs from descriptions
  4. Auto-detect categories (sneakers vs clothing) from size format
  5. Build WooCommerce product payloads
  6. Delta sync to WooCommerce

HELP;
    exit(0);
}

// Parse CLI options
$dry_run = in_array('--dry-run', $argv);
$verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$skip_media = in_array('--skip-media', $argv);
$skip_taxonomies = in_array('--skip-taxonomies', $argv);
$force_full = in_array('--force-full', $argv);
$dir = null;
$limit = null;

foreach ($argv as $arg) {
    if (strpos($arg, '--dir=') === 0) {
        $dir = str_replace('--dir=', '', $arg);
    }
    if (strpos($arg, '--limit=') === 0) {
        $limit = (int) str_replace('--limit=', '', $arg);
    }
}

if (!$dir) {
    echo "Error: --dir=DIR is required. Use --help for usage.\n";
    exit(1);
}

// Resolve relative paths
if ($dir[0] !== '/') {
    $dir = Config::projectRoot() . '/' . $dir;
}

if (!is_dir($dir)) {
    echo "Error: Directory not found: {$dir}\n";
    exit(1);
}

// ============================================================================
// Run via CatalogPipeline
// ============================================================================

$config = Config::load();

$logger = LoggerFactory::create('ShopifyImport', [
    'file' => Config::projectRoot() . '/logs/shopify-import.log',
    'console_level' => $verbose ? Logger::DEBUG : Logger::INFO,
]);

$adapter = new BulkUploadAdapter($dir, 'shopify-dir', $logger, $limit, $verbose);

$pipeline = new CatalogPipeline($config, $logger, [
    'dry_run' => $dry_run,
    'verbose' => $verbose,
    'skip_media' => $skip_media,
    'skip_taxonomies' => $skip_taxonomies,
    'force_full' => $force_full,
    'limit' => $limit,
    'feed_output_path' => Config::dataDir() . '/shopify-import-feed-wc.json',
]);

$result = $pipeline->run($adapter);

exit($result->isSuccess() ? 0 : 1);
