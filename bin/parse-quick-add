#!/usr/bin/env php
<?php
/**
 * Parse Quick Add — Convert raw product text into structured JSON
 *
 * Takes freeform text (pasted from notes, spreadsheets, etc.) and extracts
 * a clean JSON product list suitable for bin/quick-add --file=.
 *
 * Input format (flexible, one product per line):
 *   Lines with a valid SKU pattern (e.g. DD1391-100) are parsed as products.
 *   Everything after the SKU on the same line is treated as the product title.
 *   Lines without a SKU pattern are ignored (headers, comments, separators).
 *
 * Output format (same as catalog.json products):
 *   {"SKU": "title", ...}
 *
 * @package ResellPiacenza\Import
 */

// ============================================================================
// CLI
// ============================================================================

if (in_array('--help', $argv) || in_array('-h', $argv)) {
    echo <<<HELP
Parse Quick Add — Convert raw text to structured JSON product list

Usage:
  bin/parse-quick-add <input.txt>                      # Parse and print JSON
  bin/parse-quick-add <input.txt> -o products.json     # Write to file
  bin/parse-quick-add <input.txt> --output=out.json    # Write to file

Input format (one product per line, freeform):
  Any line containing a valid SKU pattern (2+ alphanumeric chars, hyphen,
  1+ alphanumeric chars) is extracted as a product. The title is everything
  after the SKU. Lines without a SKU are ignored — use them freely as
  section headers, comments, or visual separators.

  Example input:
    Nike Travis Scott
        DM7866-200  Jordan 1 Retro Low OG SP Travis Scott Medium Olive
        DM7866-202  Jordan 1 Retro Low OG SP Travis Scott Velvet Brown
    Nike Off White
        AA3830-002  Nike Air Presto Off-White Black (2018)
        FD6900-200

Output format:
  {
    "DM7866-200": "Jordan 1 Retro Low OG SP Travis Scott Medium Olive",
    "DM7866-202": "Jordan 1 Retro Low OG SP Travis Scott Velvet Brown",
    "AA3830-002": "Nike Air Presto Off-White Black (2018)",
    "FD6900-200": ""
  }

Options:
  -o FILE, --output=FILE    Write JSON to file (default: stdout)
  --help, -h                Show help

HELP;
    exit(0);
}

$input_file = null;
$output_file = null;

for ($i = 1; $i < count($argv); $i++) {
    $arg = $argv[$i];
    if (strpos($arg, '--output=') === 0) {
        $output_file = str_replace('--output=', '', $arg);
    } elseif ($arg === '-o' && isset($argv[$i + 1])) {
        $output_file = $argv[++$i];
    } elseif ($arg === '--help' || $arg === '-h') {
        continue;
    } elseif ($arg[0] !== '-') {
        $input_file = $arg;
    }
}

if (!$input_file) {
    fwrite(STDERR, "Usage: bin/parse-quick-add <input.txt> [-o output.json]\n");
    exit(1);
}

if (!file_exists($input_file)) {
    fwrite(STDERR, "File not found: {$input_file}\n");
    exit(1);
}

// ============================================================================
// Parse
// ============================================================================

$lines = file($input_file, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
$products = [];
$headers = [];

foreach ($lines as $line) {
    // Normalize unicode dashes (en-dash, em-dash) to ASCII hyphen
    $line = str_replace(['–', '—'], '-', $line);
    $line_trimmed = trim($line);

    if (empty($line_trimmed)) {
        continue;
    }

    // Try to extract a SKU pattern: 2+ alphanumeric, hyphen, 1+ alphanumeric
    // Matches: DD1391-100, AA3830-002, D06290-100, HF8813-500
    if (preg_match('/\b([A-Z0-9]{2,}-[A-Z0-9]+)\b/i', $line_trimmed, $m)) {
        $sku = strtoupper($m[1]);
        // Title = everything after the SKU, trimmed
        $pos = strpos($line_trimmed, $m[0]);
        $title = trim(substr($line_trimmed, $pos + strlen($m[0])));

        if (isset($products[$sku])) {
            fwrite(STDERR, "  WARN: duplicate SKU {$sku}, keeping first occurrence\n");
            continue;
        }

        $products[$sku] = $title;
    } else {
        // No SKU — treat as header/comment
        $headers[] = $line_trimmed;
    }
}

// ============================================================================
// Output
// ============================================================================

$json = json_encode($products, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE);

if ($output_file) {
    file_put_contents($output_file, $json . "\n");
    fwrite(STDERR, "Parsed " . count($products) . " products → {$output_file}\n");
    if (!empty($headers)) {
        fwrite(STDERR, "Skipped " . count($headers) . " header lines\n");
    }
} else {
    echo $json . "\n";
    fwrite(STDERR, "\n" . count($products) . " products parsed");
    if (!empty($headers)) {
        fwrite(STDERR, ", " . count($headers) . " headers skipped");
    }
    fwrite(STDERR, "\n");
}

exit(0);
