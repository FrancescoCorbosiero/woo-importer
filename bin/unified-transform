#!/usr/bin/env php
<?php
/**
 * CLI wrapper for Unified Feed Transformer
 *
 * Merges KicksDB (catalog master) + Golden Sneakers (pricing/stock overlay)
 * into a single WC-formatted feed. Variation-level merge: each size independently
 * gets GS real pricing when available, KicksDB market pricing otherwise.
 *
 * Pipeline: KicksDbAdapter + GoldenSneakersAdapter → FeedMerger → WcProductBuilder
 *
 * Outputs: data/feed-unified-wc-latest.json
 *
 * @package ResellPiacenza\Import
 */

require __DIR__ . '/../vendor/autoload.php';

use Monolog\Logger;
use ResellPiacenza\Support\Config;
use ResellPiacenza\Support\LoggerFactory;
use ResellPiacenza\Import\KicksDbAdapter;
use ResellPiacenza\Import\GoldenSneakersAdapter;
use ResellPiacenza\Import\FeedMerger;
use ResellPiacenza\Import\WcProductBuilder;

// ============================================================================
// CLI
// ============================================================================

if (in_array('--help', $argv) || in_array('-h', $argv)) {
    echo <<<HELP
Unified Feed Transformer
Merges KicksDB catalog + Golden Sneakers pricing into WooCommerce REST format.

Usage:
  bin/unified-transform [options]

Options:
  --limit=N         Transform first N KicksDB products only
  --skip-gs         Skip GS overlay (KicksDB only, useful for debugging)
  --verbose, -v     Detailed output
  --help, -h        Show help

Requires:
  data/kicksdb-assortment.json   (from kicksdb-discover)
  data/taxonomy-map.json         (from prepare-taxonomies)
  image-map.json                 (from prepare-media, optional)

Output:
  data/feed-unified-wc-latest.json - Merged WooCommerce REST API formatted products
  data/unified-sku-cache.json      - SKU cache for cross-pipeline dedup

Examples:
  bin/unified-transform                    # Full merge + transform
  bin/unified-transform --limit=10         # First 10 KicksDB products
  bin/unified-transform --skip-gs          # KicksDB only (no GS overlay)
  bin/unified-transform --verbose          # Detailed output

HELP;
    exit(0);
}

$verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$skip_gs = in_array('--skip-gs', $argv);
$limit = null;

foreach ($argv as $arg) {
    if (strpos($arg, '--limit=') === 0) {
        $limit = (int) str_replace('--limit=', '', $arg);
    }
}

// ============================================================================
// Setup
// ============================================================================

$config = Config::load();
$start_time = microtime(true);

$logger = LoggerFactory::create('UnifiedTransform', [
    'file' => Config::projectRoot() . '/logs/unified-transform.log',
    'console_level' => $verbose ? Logger::DEBUG : Logger::INFO,
]);

$logger->info('');
$logger->info('================================');
$logger->info('  Unified Feed Transformer');
$logger->info('  KicksDB + GS → merged WC REST format');
$logger->info('================================');
$logger->info('');

// ============================================================================
// Load KicksDB Assortment
// ============================================================================

$assortment_file = Config::dataDir() . '/kicksdb-assortment.json';

if (!file_exists($assortment_file)) {
    $logger->error("Assortment file not found: {$assortment_file}");
    $logger->error("Run bin/kicksdb-discover first.");
    exit(1);
}

$assortment = json_decode(file_get_contents($assortment_file), true);
if (!is_array($assortment) || empty($assortment['products'])) {
    $logger->error("Invalid or empty assortment file.");
    exit(1);
}

$products = $assortment['products'];
$logger->info("Loaded assortment: " . count($products) . " products (discovered {$assortment['discovered_at']})");

// Extract SKU list
$skus = array_column($products, 'sku');
$skus = array_values(array_filter($skus));

if ($limit && count($skus) > $limit) {
    $skus = array_slice($skus, 0, $limit);
    $logger->info("  Limited to first {$limit}");
}

$logger->info("  {" . count($skus) . "} SKUs to transform");

// ============================================================================
// Fetch from both sources
// ============================================================================

try {
    // KicksDB adapter
    $kdbAdapter = new KicksDbAdapter($config, $skus, $logger);

    // Show pricing config
    $pricing_summary = $kdbAdapter->getPricingSummary();
    $logger->info("  KicksDB pricing: flat {$pricing_summary['flat_margin']}, floor {$pricing_summary['floor_price']}, rounding {$pricing_summary['rounding']}");
    if (!empty($pricing_summary['tiers'])) {
        foreach ($pricing_summary['tiers'] as $tier) {
            $logger->info("    Tier: {$tier}");
        }
    }
    $logger->info('');

    // Collect KicksDB normalized products (must materialize since we need random access)
    $logger->info('Fetching KicksDB products...');
    $kdbProducts = [];
    foreach ($kdbAdapter->fetchProducts() as $p) {
        $kdbProducts[] = $p;
    }
    $logger->info("  KicksDB: " . count($kdbProducts) . " products normalized");

    // GS adapter (unless --skip-gs)
    $gsProducts = [];
    if (!$skip_gs) {
        $logger->info('');
        $logger->info('Fetching Golden Sneakers products...');
        $gsAdapter = new GoldenSneakersAdapter($config, $logger);
        foreach ($gsAdapter->fetchProducts() as $p) {
            $gsProducts[] = $p;
        }
        $logger->info("  GS: " . count($gsProducts) . " products normalized");
    } else {
        $logger->info('Skipping GS overlay (--skip-gs)');
    }

    // ========================================================================
    // Merge
    // ========================================================================

    $logger->info('');
    $logger->info('Merging feeds (variation-level)...');

    $merger = new FeedMerger($logger);
    $mergedProducts = $merger->merge($kdbProducts, $gsProducts);

    $merge_stats = $merger->getStats();
    $logger->info("  Merged:       {$merge_stats['products_merged']} products");
    $logger->info("  KicksDB-only: {$merge_stats['products_kicksdb_only']} products");
    $logger->info("  GS-only:      {$merge_stats['products_gs_only']} products");
    $logger->info("  Variations - GS overlay: {$merge_stats['variations_gs_overlay']}, KDB-only: {$merge_stats['variations_kicksdb_only']}, GS-only: {$merge_stats['variations_gs_only']}");

    // ========================================================================
    // Build WC format
    // ========================================================================

    $logger->info('');
    $logger->info('Building WooCommerce payloads...');

    $builder = new WcProductBuilder($config, $logger);
    $builder->setStockOverride(null); // Use adapter/merger-provided stock
    $wc_products = $builder->buildAll($mergedProducts);

    // Sort by release_date (newest first) for menu_order assignment
    usort($wc_products, function ($a, $b) {
        $date_a = 0;
        $date_b = 0;
        foreach ($a['meta_data'] ?? [] as $m) {
            if ($m['key'] === '_release_date' && !empty($m['value'])) {
                $date_a = strtotime(preg_replace('/T.*$/', '', $m['value'])) ?: 0;
                break;
            }
        }
        foreach ($b['meta_data'] ?? [] as $m) {
            if ($m['key'] === '_release_date' && !empty($m['value'])) {
                $date_b = strtotime(preg_replace('/T.*$/', '', $m['value'])) ?: 0;
                break;
            }
        }
        return $date_b - $date_a; // Newest first
    });

    // Assign menu_order based on release recency (0 = most recent)
    $release_ordered = 0;
    foreach ($wc_products as $idx => &$wc_tmp) {
        $wc_tmp['menu_order'] = $idx;
        foreach ($wc_tmp['meta_data'] ?? [] as $m) {
            if ($m['key'] === '_release_date' && !empty($m['value'])) {
                $release_ordered++;
                break;
            }
        }
    }
    unset($wc_tmp);
    $logger->info("Release ordering: {$release_ordered}/{" . count($wc_products) . "} products have release dates");

    // Enrich WC products with catalog brand hierarchy
    $catalog = $assortment['catalog'] ?? null;
    if ($catalog) {
        $taxonomy_map_file = Config::dataDir() . '/taxonomy-map.json';
        $taxonomy_map = file_exists($taxonomy_map_file)
            ? (json_decode(file_get_contents($taxonomy_map_file), true) ?: [])
            : [];
        $brands_map = $taxonomy_map['brands'] ?? [];

        // Build SKU → catalog metadata lookup from assortment products
        $catalog_meta = [];
        foreach ($assortment['products'] as $p) {
            if (!empty($p['catalog_subcategory'])) {
                $catalog_meta[$p['sku']] = [
                    'brand' => $p['catalog_brand'] ?? '',
                    'subcategory' => $p['catalog_subcategory'] ?? '',
                ];
            }
        }

        $catalog_enriched = 0;
        foreach ($wc_products as &$wc) {
            $sku = $wc['sku'] ?? '';
            if (!isset($catalog_meta[$sku])) {
                continue;
            }

            $meta = $catalog_meta[$sku];
            $brand_slug = strtolower(preg_replace('/[^a-z0-9-]/i', '-', $meta['brand']));
            $brand_slug = preg_replace('/-+/', '-', trim($brand_slug, '-'));
            $subcat_slug = strtolower(preg_replace('/[^a-z0-9-]/i', '-', $meta['subcategory']));
            $subcat_slug = preg_replace('/-+/', '-', trim($subcat_slug, '-'));

            $subcat_brand_id = $brands_map[$subcat_slug] ?? null;
            $parent_brand_id = $brands_map[$brand_slug] ?? null;

            $brand_ids = [];
            if ($subcat_brand_id) {
                $brand_ids[] = ['id' => $subcat_brand_id];
            }
            if ($parent_brand_id && $parent_brand_id !== $subcat_brand_id) {
                $brand_ids[] = ['id' => $parent_brand_id];
            }

            if (!empty($brand_ids)) {
                $existing = $wc['brands'] ?? [];
                $existing_ids = array_column($existing, 'id');
                foreach ($brand_ids as $b) {
                    if (!in_array($b['id'], $existing_ids)) {
                        $existing[] = $b;
                    }
                }
                $wc['brands'] = $existing;
            }

            $wc['meta_data'] = $wc['meta_data'] ?? [];
            $wc['meta_data'][] = ['key' => '_catalog_brand', 'value' => $meta['brand']];
            $wc['meta_data'][] = ['key' => '_catalog_subcategory', 'value' => $meta['subcategory']];

            $catalog_enriched++;
        }
        unset($wc);

        $logger->info("Catalog enrichment: {$catalog_enriched}/{" . count($wc_products) . "} products assigned sub-brands");
    }

    // ========================================================================
    // Write output
    // ========================================================================

    $output_file = Config::dataDir() . '/feed-unified-wc-latest.json';
    file_put_contents(
        $output_file,
        json_encode($wc_products, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE)
    );

    // Cache unified SKUs for cross-pipeline dedup
    $unified_skus = array_values(array_filter(array_map(fn($p) => $p['sku'] ?? null, $wc_products)));
    file_put_contents(Config::dataDir() . '/unified-sku-cache.json', json_encode($unified_skus, JSON_PRETTY_PRINT));
    $logger->info("Cached " . count($unified_skus) . " unified SKUs to data/unified-sku-cache.json");

    // ========================================================================
    // Summary
    // ========================================================================

    $duration = round(microtime(true) - $start_time, 1);
    $kdb_stats = $kdbAdapter->getStats();
    $gs_stats = isset($gsAdapter) ? $gsAdapter->getStats() : null;
    $builder_stats = $builder->getStats();

    $logger->info('');
    $logger->info('================================');
    $logger->info('  UNIFIED TRANSFORM SUMMARY');
    $logger->info('================================');
    $logger->info("  KicksDB SKUs requested:   {$kdb_stats['total_skus']}");
    $logger->info("  KicksDB products found:   {$kdb_stats['products_found']}");
    $logger->info("  KicksDB not found:        {$kdb_stats['products_not_found']}");
    if ($gs_stats) {
        $logger->info("  GS products fetched:      {$gs_stats['fetched']}");
    } else {
        $logger->info("  GS: skipped (--skip-gs)");
    }
    $logger->info("  ---");
    $logger->info("  Merged (both sources):    {$merge_stats['products_merged']}");
    $logger->info("  KicksDB-only:             {$merge_stats['products_kicksdb_only']}");
    $logger->info("  GS-only:                  {$merge_stats['products_gs_only']}");
    $logger->info("  Var GS overlay:           {$merge_stats['variations_gs_overlay']}");
    $logger->info("  Var KicksDB-only:         {$merge_stats['variations_kicksdb_only']}");
    $logger->info("  Var GS-only:              {$merge_stats['variations_gs_only']}");
    $logger->info("  ---");
    $logger->info("  WC products built:        {$builder_stats['transformed']}");
    $logger->info("  With image:               {$builder_stats['with_image']}");
    $logger->info("  With gallery:             {$builder_stats['with_gallery']}");
    $logger->info("  Without image:            {$builder_stats['without_image']}");
    $logger->info("  Duration:                 {$duration}s");
    $logger->info("  Output:                   {$output_file}");
    $logger->info('================================');

    exit(0);

} catch (\Exception $e) {
    $logger->error('Error: ' . $e->getMessage());
    exit(1);
}
