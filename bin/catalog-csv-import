#!/usr/bin/env php
<?php
/**
 * Catalog CSV Import — Converts a CSV catalog into data/catalog.json
 *
 * Reads a CSV file with columns: Sezione, Marca, Sottocategoria, SKU, ...
 * Only the first 4 columns are used; remaining columns (Taglie, Prezzo, etc.)
 * are ignored (reference-only for human editors).
 *
 * Rows without a SKU define the taxonomy structure (sections/brands/subcategories).
 * Rows with a SKU are products placed under their section/brand/subcategory.
 * Row order determines product ordering (menu_order in WooCommerce).
 *
 * The existing catalog.json is used as a base to preserve fields not in the CSV
 * (e.g. product_types, keywords). If no catalog.json exists, a fresh one is created.
 *
 * @package ResellPiacenza\Import
 */

$autoloader = __DIR__ . '/../vendor/autoload.php';
if (file_exists($autoloader)) {
    require $autoloader;
    $data_dir = \ResellPiacenza\Support\Config::dataDir();
    $project_root = \ResellPiacenza\Support\Config::projectRoot();
} else {
    $project_root = realpath(__DIR__ . '/..');
    $data_dir = $project_root . '/data';
}

// ============================================================================
// CLI
// ============================================================================

if (in_array('--help', $argv) || in_array('-h', $argv)) {
    echo <<<HELP
Catalog CSV Import — Convert CSV to catalog.json

Usage:
  bin/catalog-csv-import [options]

Options:
  --csv=FILE        CSV file to import (default: data/catalog.csv)
  --output=FILE     Output JSON file (default: data/catalog.json)
  --merge           Merge CSV products into existing catalog (add new SKUs only)
  --wc-snapshot=FILE  Also exclude SKUs found in this WC export CSV (use with --merge)
  --dry-run         Preview without writing
  --verbose, -v     Show detailed output
  --help, -h        Show help

CSV format:
  Sezione,Marca,Sottocategoria,SKU,Titolo,Query,Taglie,Prezzo,Prezzo Scontato
  Sneakers,Nike,Nike Dunk,DD1391-100,Nike Dunk Low Panda,Nike Dunk,40-45,120,
  Abbigliamento,Supreme,,SUP-SKU-1,Supreme Box Logo Tee,Supreme T-Shirt,S/M/L,89,79
  Accessori,,Beanie,BEANIE-SKU-1,Nike ACG Beanie,beanie,,,

  - Sezione: Section name (Sneakers, Abbigliamento, Accessori)
  - Marca: Brand name (empty for Accessori)
  - Sottocategoria: Subcategory (product line for Sneakers, item name for Accessori, empty for Abbigliamento)
  - SKU: Product SKU from KicksDB (empty rows define structure only)
  - Titolo: Product title from KicksDB (reference-only, ignored by importer)
  - Query: KicksDB search query used to find this product (reference-only, ignored by importer)
  - Remaining columns are ignored (reference-only for human editors)

Examples:
  bin/catalog-csv-import                              # Default: data/catalog.csv → data/catalog.json
  bin/catalog-csv-import --csv=my-catalog.csv         # Custom input
  bin/catalog-csv-import --merge --csv=new-products.csv  # Add new products to existing catalog
  bin/catalog-csv-import --merge --csv=new.csv --wc-snapshot=data/wc-snap.csv  # Skip WC duplicates
  bin/catalog-csv-import --dry-run --verbose           # Preview

HELP;
    exit(0);
}

$opt_verbose = in_array('--verbose', $argv) || in_array('-v', $argv);
$opt_dry_run = in_array('--dry-run', $argv);
$opt_merge = in_array('--merge', $argv);
$opt_csv = null;
$opt_output = null;
$opt_wc_snapshot = null;

foreach ($argv as $arg) {
    if (strpos($arg, '--csv=') === 0) {
        $opt_csv = str_replace('--csv=', '', $arg);
    }
    if (strpos($arg, '--output=') === 0) {
        $opt_output = str_replace('--output=', '', $arg);
    }
    if (strpos($arg, '--wc-snapshot=') === 0) {
        $opt_wc_snapshot = str_replace('--wc-snapshot=', '', $arg);
    }
}

$csv_file = $opt_csv ?? $data_dir . '/catalog.csv';
$output_file = $opt_output ?? $data_dir . '/catalog.json';

// Resolve relative paths
if ($csv_file && !preg_match('#^/#', $csv_file)) {
    $csv_file = $project_root . '/' . $csv_file;
}
if ($output_file && !preg_match('#^/#', $output_file)) {
    $output_file = $project_root . '/' . $output_file;
}

if (!file_exists($csv_file)) {
    fwrite(STDERR, "CSV file not found: {$csv_file}\n");
    exit(1);
}

// ============================================================================
// Load existing catalog.json as base (preserves product_types, keywords, etc.)
// ============================================================================

$base_catalog = null;
if (file_exists($output_file)) {
    $base_catalog = json_decode(file_get_contents($output_file), true);
}

// Build lookup from base catalog for section/brand/item metadata
$base_sections = [];
if ($base_catalog && !empty($base_catalog['sections'])) {
    foreach ($base_catalog['sections'] as $section) {
        $base_sections[$section['name']] = $section;
    }
}

// ============================================================================
// Parse CSV
// ============================================================================

$handle = fopen($csv_file, 'r');
if ($handle === false) {
    fwrite(STDERR, "Cannot open CSV file: {$csv_file}\n");
    exit(1);
}

// Read header
$header = fgetcsv($handle);
if ($header === false || count($header) < 4) {
    fwrite(STDERR, "Invalid CSV header. Expected at least: Sezione,Marca,Sottocategoria,SKU\n");
    exit(1);
}

// Normalize header (trim whitespace, case-insensitive lookup)
$header = array_map('trim', $header);
$col_map = array_flip(array_map('strtolower', $header));

$col_sezione = $col_map['sezione'] ?? 0;
$col_marca = $col_map['marca'] ?? 1;
$col_sottocategoria = $col_map['sottocategoria'] ?? 2;
$col_sku = $col_map['sku'] ?? 3;
$col_query = $col_map['query'] ?? null;

// Collect rows
$rows = [];
$line = 1;
while (($row = fgetcsv($handle)) !== false) {
    $line++;
    if (empty(array_filter($row))) {
        continue; // Skip blank lines
    }

    $sezione = trim($row[$col_sezione] ?? '');
    $marca = trim($row[$col_marca] ?? '');
    $sottocategoria = trim($row[$col_sottocategoria] ?? '');
    $sku = trim($row[$col_sku] ?? '');

    if (empty($sezione)) {
        if ($opt_verbose) {
            fwrite(STDERR, "  SKIP line {$line}: empty Sezione\n");
        }
        continue;
    }

    $query = ($col_query !== null) ? trim($row[$col_query] ?? '') : '';

    $rows[] = [
        'sezione' => $sezione,
        'marca' => $marca,
        'sottocategoria' => $sottocategoria,
        'sku' => $sku,
        'query' => $query,
    ];
}
fclose($handle);

echo "Parsed {$csv_file}: " . count($rows) . " rows\n";

// ============================================================================
// Build catalog.json structure
// ============================================================================

// Section slug mapping
$section_slugs = [
    'Sneakers' => 'sneakers',
    'Abbigliamento' => 'abbigliamento',
    'Accessori' => 'accessori',
];

$section_wc_categories = [
    'Sneakers' => 'sneakers',
    'Abbigliamento' => 'clothing',
    'Accessori' => 'accessories',
];

$sections = []; // name → section data
$section_order = []; // preserve CSV section order
$existing_skus = []; // SKU set for --merge deduplication
$query_map = []; // SKU → query fallback for KicksDB lookup

// ============================================================================
// Pre-populate from existing catalog when --merge is active
// ============================================================================

if ($opt_merge && $base_catalog && !empty($base_catalog['sections'])) {
    echo "Merge mode: loading existing catalog as base\n";

    foreach ($base_catalog['sections'] as $base_sec) {
        $sezione = $base_sec['name'];
        $section_order[] = $sezione;

        $sections[$sezione] = [
            'name' => $sezione,
            'slug' => $base_sec['slug'] ?? $section_slugs[$sezione] ?? strtolower($sezione),
            'wc_category' => $base_sec['wc_category'] ?? $section_wc_categories[$sezione] ?? strtolower($sezione),
        ];

        if (!empty($base_sec['subcategories'])) {
            $sections[$sezione]['subcategories'] = $base_sec['subcategories'];
        }

        $sections[$sezione]['_brands'] = [];
        $sections[$sezione]['_brand_data'] = [];
        $sections[$sezione]['_items'] = [];
        $sections[$sezione]['_item_data'] = [];

        // Replay brands
        foreach ($base_sec['brands'] ?? [] as $brand) {
            $brand_name = $brand['name'];
            $sections[$sezione]['_brands'][] = $brand_name;
            $sections[$sezione]['_brand_data'][$brand_name] = [
                'name' => $brand_name,
                'products' => $brand['products'] ?? [],
                '_subcats' => [],
                '_subcat_data' => [],
            ];

            foreach ($brand['products'] ?? [] as $sku) {
                $existing_skus[$sku] = true;
            }

            foreach ($brand['subcategories'] ?? [] as $subcat) {
                $subcat_name = $subcat['name'];
                $sections[$sezione]['_brand_data'][$brand_name]['_subcats'][] = $subcat_name;
                $sections[$sezione]['_brand_data'][$brand_name]['_subcat_data'][$subcat_name] = [
                    'name' => $subcat_name,
                    'products' => $subcat['products'] ?? [],
                ];

                foreach ($subcat['products'] ?? [] as $sku) {
                    $existing_skus[$sku] = true;
                }
            }
        }

        // Replay items (Accessori)
        foreach ($base_sec['items'] ?? [] as $item) {
            $item_name = $item['name'];
            $sections[$sezione]['_items'][] = $item_name;

            $item_data = ['name' => $item_name, 'products' => $item['products'] ?? []];
            if (!empty($item['product_types'])) {
                $item_data['product_types'] = $item['product_types'];
            }

            $sections[$sezione]['_item_data'][$item_name] = $item_data;

            foreach ($item['products'] ?? [] as $sku) {
                $existing_skus[$sku] = true;
            }
        }
    }

    // Preserve existing query_map
    if (!empty($base_catalog['query_map'])) {
        $query_map = $base_catalog['query_map'];
    }

    echo "  Existing catalog: " . count($existing_skus) . " SKUs\n";
}

// ============================================================================
// Load WC snapshot for additional dedup (--wc-snapshot)
// ============================================================================

if ($opt_wc_snapshot) {
    $wc_snap_file = $opt_wc_snapshot;
    if (!preg_match('#^/#', $wc_snap_file)) {
        $wc_snap_file = $project_root . '/' . $wc_snap_file;
    }

    if (!file_exists($wc_snap_file)) {
        fwrite(STDERR, "WC snapshot file not found: {$wc_snap_file}\n");
        exit(1);
    }

    $wc_handle = fopen($wc_snap_file, 'r');
    if ($wc_handle === false) {
        fwrite(STDERR, "Cannot open WC snapshot file: {$wc_snap_file}\n");
        exit(1);
    }

    // Read header and find SKU column
    $wc_header = fgetcsv($wc_handle);
    $wc_header_map = array_flip(array_map('strtolower', array_map('trim', $wc_header)));
    $wc_col_sku = $wc_header_map['sku'] ?? $wc_header_map['sku'] ?? 3;

    $wc_snap_count = 0;
    $wc_snap_new = 0;
    while (($wc_row = fgetcsv($wc_handle)) !== false) {
        $wc_sku = trim($wc_row[$wc_col_sku] ?? '');
        if (!empty($wc_sku)) {
            $wc_snap_count++;
            if (!isset($existing_skus[$wc_sku])) {
                $existing_skus[$wc_sku] = true;
                $wc_snap_new++;
            }
        }
    }
    fclose($wc_handle);

    echo "WC snapshot: {$wc_snap_file}\n";
    echo "  {$wc_snap_count} SKUs in WC, {$wc_snap_new} not already in catalog\n";
}

$skus_added = 0;
$skus_skipped = 0;

foreach ($rows as $row) {
    $sezione = $row['sezione'];
    $marca = $row['marca'];
    $sottocategoria = $row['sottocategoria'];
    $sku = $row['sku'];
    $query = $row['query'] ?? '';

    // Collect query fallback for KicksDB lookup
    if (!empty($sku) && !empty($query) && $query !== $sku) {
        $query_map[$sku] = $query;
    }

    // Initialize section if first encounter
    if (!isset($sections[$sezione])) {
        $section_order[] = $sezione;

        // Pull metadata from base catalog if available
        $base = $base_sections[$sezione] ?? [];

        $sections[$sezione] = [
            'name' => $sezione,
            'slug' => $base['slug'] ?? $section_slugs[$sezione] ?? strtolower($sezione),
            'wc_category' => $base['wc_category'] ?? $section_wc_categories[$sezione] ?? strtolower($sezione),
        ];

        // Preserve keyword subcategories from base catalog (Abbigliamento)
        if (!empty($base['subcategories'])) {
            $sections[$sezione]['subcategories'] = $base['subcategories'];
        }

        // Initialize containers
        $sections[$sezione]['_brands'] = [];    // ordered brand names
        $sections[$sezione]['_brand_data'] = []; // brand name → data
        $sections[$sezione]['_items'] = [];      // ordered item names
        $sections[$sezione]['_item_data'] = [];  // item name → data
    }

    $sec = &$sections[$sezione];

    // Determine section type based on content
    $is_accessori = empty($marca) && !empty($sottocategoria);
    $is_brand = !empty($marca);

    if ($is_accessori) {
        // Accessori: items[].products[]
        if (!isset($sec['_item_data'][$sottocategoria])) {
            $sec['_items'][] = $sottocategoria;

            // Pull product_types from base catalog
            $base_item = null;
            $base_sec = $base_sections[$sezione] ?? [];
            foreach ($base_sec['items'] ?? [] as $bi) {
                if (($bi['name'] ?? $bi['label'] ?? '') === $sottocategoria) {
                    $base_item = $bi;
                    break;
                }
            }

            $item_data = ['name' => $sottocategoria, 'products' => []];
            if ($base_item && !empty($base_item['product_types'])) {
                $item_data['product_types'] = $base_item['product_types'];
            }

            $sec['_item_data'][$sottocategoria] = $item_data;
        }

        if (!empty($sku)) {
            if (($opt_merge || $opt_wc_snapshot) && isset($existing_skus[$sku])) {
                $skus_skipped++;
                if ($opt_verbose) {
                    fwrite(STDERR, "  SKIP duplicate SKU: {$sku}\n");
                }
            } else {
                $sec['_item_data'][$sottocategoria]['products'][] = $sku;
                $existing_skus[$sku] = true;
                $skus_added++;
            }
        }
    } elseif ($is_brand) {
        // Brand-based section — always support both flat products and subcategories
        if (!isset($sec['_brand_data'][$marca])) {
            $sec['_brands'][] = $marca;
            $sec['_brand_data'][$marca] = [
                'name' => $marca,
                'products' => [],
                '_subcats' => [],
                '_subcat_data' => [],
            ];
        }

        $brand = &$sec['_brand_data'][$marca];

        if (!empty($sottocategoria)) {
            // Sneakers-style: brands[].subcategories[].products[]
            if (!isset($brand['_subcat_data'][$sottocategoria])) {
                $brand['_subcats'][] = $sottocategoria;
                $brand['_subcat_data'][$sottocategoria] = ['name' => $sottocategoria, 'products' => []];
            }
            if (!empty($sku)) {
                if (($opt_merge || $opt_wc_snapshot) && isset($existing_skus[$sku])) {
                    $skus_skipped++;
                    if ($opt_verbose) {
                        fwrite(STDERR, "  SKIP duplicate SKU: {$sku}\n");
                    }
                } else {
                    $brand['_subcat_data'][$sottocategoria]['products'][] = $sku;
                    $existing_skus[$sku] = true;
                    $skus_added++;
                }
            }
        } else {
            // Flat products (no subcategory)
            if (!empty($sku)) {
                if (($opt_merge || $opt_wc_snapshot) && isset($existing_skus[$sku])) {
                    $skus_skipped++;
                    if ($opt_verbose) {
                        fwrite(STDERR, "  SKIP duplicate SKU: {$sku}\n");
                    }
                } else {
                    $brand['products'][] = $sku;
                    $existing_skus[$sku] = true;
                    $skus_added++;
                }
            }
        }

        unset($brand);
    }

    unset($sec);
}

// ============================================================================
// Assemble final catalog.json
// ============================================================================

$catalog = ['sections' => []];
$total_skus = 0;

foreach ($section_order as $sezione) {
    $sec = $sections[$sezione];
    $section_out = [
        'name' => $sec['name'],
        'slug' => $sec['slug'],
        'wc_category' => $sec['wc_category'],
    ];

    // Preserve keyword subcategories (Abbigliamento)
    if (!empty($sec['subcategories'])) {
        $section_out['subcategories'] = $sec['subcategories'];
    }

    // Brands
    if (!empty($sec['_brands'])) {
        $section_out['brands'] = [];
        foreach ($sec['_brands'] as $brand_name) {
            $brand = $sec['_brand_data'][$brand_name];
            $brand_out = ['name' => $brand['name']];

            $has_subcats = !empty($brand['_subcats']);
            $has_flat = !empty($brand['products']);

            if ($has_subcats) {
                // Sneakers-style with subcategories
                $brand_out['subcategories'] = [];

                // If brand has flat products alongside subcategories,
                // put them in a default subcategory named after the brand
                if ($has_flat) {
                    $default_subcat_name = $brand['name'] . ' Altro';
                    $brand_out['subcategories'][] = [
                        'name' => $default_subcat_name,
                        'products' => $brand['products'],
                    ];
                    $total_skus += count($brand['products']);
                }

                foreach ($brand['_subcats'] as $subcat_name) {
                    $subcat = $brand['_subcat_data'][$subcat_name];
                    $brand_out['subcategories'][] = [
                        'name' => $subcat['name'],
                        'products' => $subcat['products'],
                    ];
                    $total_skus += count($subcat['products']);
                }
            } elseif ($has_flat) {
                // Abbigliamento-style flat products only
                $brand_out['products'] = $brand['products'];
                $total_skus += count($brand_out['products']);
            }

            $section_out['brands'][] = $brand_out;
        }
    }

    // Items (Accessori)
    if (!empty($sec['_items'])) {
        $section_out['items'] = [];
        foreach ($sec['_items'] as $item_name) {
            $item = $sec['_item_data'][$item_name];
            $item_out = ['name' => $item['name']];

            if (!empty($item['product_types'])) {
                $item_out['product_types'] = $item['product_types'];
            }

            $item_out['products'] = $item['products'];
            $total_skus += count($item['products']);
            $section_out['items'][] = $item_out;
        }
    }

    $catalog['sections'][] = $section_out;
}

// Add query_map for KicksDB fallback lookup
if (!empty($query_map)) {
    $catalog['query_map'] = $query_map;
}

// ============================================================================
// Output
// ============================================================================

echo "Built catalog: " . count($catalog['sections']) . " sections, {$total_skus} SKUs\n";
if (!empty($query_map)) {
    echo "  Query map: " . count($query_map) . " SKUs with fallback queries\n";
}

if ($opt_merge || $opt_wc_snapshot) {
    echo "  Merge: {$skus_added} new SKUs added, {$skus_skipped} duplicates skipped\n";
}

foreach ($catalog['sections'] as $sec) {
    $sec_skus = 0;
    foreach ($sec['brands'] ?? [] as $b) {
        if (isset($b['subcategories'])) {
            foreach ($b['subcategories'] as $sc) {
                $sec_skus += count($sc['products']);
            }
        } else {
            $sec_skus += count($b['products'] ?? []);
        }
    }
    foreach ($sec['items'] ?? [] as $item) {
        $sec_skus += count($item['products']);
    }
    echo "  {$sec['name']}: {$sec_skus} SKUs\n";
}

if ($opt_dry_run) {
    echo "\n[DRY RUN] Would write to {$output_file}\n";
    if ($opt_verbose) {
        echo json_encode($catalog, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . "\n";
    }
} else {
    file_put_contents(
        $output_file,
        json_encode($catalog, JSON_PRETTY_PRINT | JSON_UNESCAPED_UNICODE) . "\n"
    );
    echo "\nWritten to {$output_file}\n";
}

exit(0);
